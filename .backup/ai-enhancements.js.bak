/* ============================================================
   MURAD LEARNING PLANNER - AI Enhancements Module v2.0
   Phase 2: Provider Diagnostics + Debugger UI
   Phase 3: Multi-provider, extended file support
   Phase 6: Analytics with real scores
   Phase 7: Condition-based Automation Builder
   Phase 8: Multiple Personality Profiles
   Phase 9: AI Dashboard Widget (Daily Intelligence Report)
   ============================================================ */

/* ============================================================
   PHASE 2 — PROVIDER DIAGNOSTICS & DEBUGGER UI ENHANCEMENTS
   ============================================================ */

/**
 * Enhanced AI Settings Page with real validation, diagnostics, debugger
 */
function renderAISettingsPageEnhanced() {
  const container = document.getElementById('page-ai-settings');
  if (!container) return;

  const providers = AIProviders.getAll();
  const active = AIProviders.getActiveProvider();
  const logs = window.AIRequestLogger ? AIRequestLogger.getAll() : [];

  container.innerHTML = `
    <div class="ai-settings-layout">
      <div class="ai-page-header">
        <h1><i class="fas fa-cog"></i> <span>${t('ai.settings.title')}</span></h1>
        <div class="ai-page-header-actions">
          <button class="btn-secondary" onclick="openAddProviderModal()">
            <i class="fas fa-plus"></i> ${t('ai.settings.addProvider')}
          </button>
        </div>
      </div>

      <!-- Active Status Banner -->
      ${active ? `
      <div class="ai-active-banner">
        <div class="active-banner-info">
          <i class="fas fa-circle" style="color:#22c55e;font-size:10px"></i>
          <span>${t('ai.settings.activeProvider')}: <strong>${active.name}</strong></span>
          <span class="active-divider">|</span>
          <span>${t('ai.settings.activeModel')}: <strong>${AIProviders.getActiveModel()?.name || '—'}</strong></span>
        </div>
        <div class="active-provider-status" id="activeProviderStatus">
          ${_renderProviderStatusBadge(active.connectionStatus || 'untested')}
        </div>
      </div>` : ''}

      <!-- Tabs -->
      <div class="ai-settings-tabs">
        <button class="ai-tab active" onclick="switchSettingsTab(event,'providers')" data-tab="providers">
          <i class="fas fa-server"></i> ${t('ai.settings.providers')}
        </button>
        <button class="ai-tab" onclick="switchSettingsTab(event,'diagnostics')" data-tab="diagnostics">
          <i class="fas fa-stethoscope"></i> ${t('ai.settings.diagnostics')}
        </button>
        <button class="ai-tab" onclick="switchSettingsTab(event,'debugger')" data-tab="debugger">
          <i class="fas fa-bug"></i> ${t('ai.settings.debugger')}
          ${logs.length > 0 ? `<span class="tab-badge">${Math.min(logs.length, 99)}</span>` : ''}
        </button>
      </div>

      <!-- Providers Tab -->
      <div class="ai-tab-content active" id="settingsTab_providers">
        <div class="provider-grid">
          ${providers.map(p => _renderProviderCard(p, active?.id === p.id)).join('')}
        </div>
      </div>

      <!-- Diagnostics Tab -->
      <div class="ai-tab-content" id="settingsTab_diagnostics">
        ${_renderDiagnosticsContent(providers)}
      </div>

      <!-- Debugger Tab -->
      <div class="ai-tab-content" id="settingsTab_debugger">
        ${_renderDebuggerContent(logs)}
      </div>
    </div>

    <!-- Provider Modal -->
    <div class="ai-modal" id="providerModal" style="display:none">
      <div class="ai-modal-overlay" onclick="closeProviderModal()"></div>
      <div class="ai-modal-content" id="providerModalContent"></div>
    </div>

    <!-- Model Modal -->
    <div class="ai-modal" id="modelModal" style="display:none">
      <div class="ai-modal-overlay" onclick="closeModelModal()"></div>
      <div class="ai-modal-content" id="modelModalContent"></div>
    </div>
  `;
}

function _renderProviderStatusBadge(status) {
  const disp = window.AIProviderValidator ? AIProviderValidator.getStatusDisplay(status) : { label: status, color: '#6b7280', icon: 'fa-circle' };
  return `<span class="provider-status-badge" style="color:${disp.color}"><i class="fas ${disp.icon}"></i> ${disp.label}</span>`;
}

function _renderProviderCard(provider, isActive) {
  const diag = window.AIProviderDiagnostics ? AIProviderDiagnostics.get(provider.id) : null;
  const status = provider.connectionStatus || 'untested';
  const statusDisp = window.AIProviderValidator ? AIProviderValidator.getStatusDisplay(status) : { label: status, color: '#6b7280', icon: 'fa-circle' };
  const avgLatency = diag ? AIProviderDiagnostics.getAverageLatency(provider.id) : 0;

  return `
    <div class="provider-card ${isActive ? 'active' : ''} status-${status}" data-provider-id="${provider.id}">
      <div class="provider-card-header">
        <div class="provider-icon" style="background:${provider.color || '#6c63ff'}22; color:${provider.color || '#6c63ff'}">
          <i class="fas ${provider.icon || 'fa-robot'}"></i>
        </div>
        <div class="provider-info">
          <h3>${_escHtml(provider.name)}</h3>
          <span class="provider-url">${_escHtml(provider.baseUrl || '')}</span>
        </div>
        <div class="provider-status" style="color:${statusDisp.color}">
          <i class="fas ${statusDisp.icon}"></i>
          <span>${statusDisp.label}</span>
        </div>
      </div>

      ${diag ? `
      <div class="provider-mini-stats">
        <span><i class="fas fa-tachometer-alt"></i> ${avgLatency}ms</span>
        <span><i class="fas fa-exchange-alt"></i> ${diag.requestCount || 0} req</span>
        <span><i class="fas fa-times-circle"></i> ${diag.errorCount || 0} err</span>
        <span><i class="fas fa-coins"></i> ${diag.totalTokens || 0} tok</span>
      </div>` : ''}

      <div class="provider-models-preview">
        ${(provider.models || []).slice(0, 3).map(m =>
          `<span class="model-chip ${AIProviders.getActiveModel()?.id === m.id ? 'active' : ''}" 
                onclick="AIProviders.setActive('${provider.id}','${m.id}');renderAISettingsPage()">
            ${_escHtml(m.name)}
          </span>`
        ).join('')}
        ${(provider.models || []).length > 3 ? `<span class="model-chip-more">+${provider.models.length - 3}</span>` : ''}
      </div>

      <div class="provider-card-actions">
        ${isActive ?
          `<span class="active-badge"><i class="fas fa-check"></i> Active</span>` :
          `<button class="btn-xs btn-primary" onclick="AIProviders.setActive('${provider.id}');renderAISettingsPage()">Set Active</button>`
        }
        <button class="btn-xs btn-secondary" onclick="testProviderConnection('${provider.id}')" id="testBtn_${provider.id}">
          <i class="fas fa-plug"></i> ${t('ai.settings.testConnection')}
        </button>
        <button class="btn-xs btn-ghost" onclick="openEditProviderModal('${provider.id}')">
          <i class="fas fa-edit"></i>
        </button>
        <button class="btn-xs btn-danger" onclick="deleteProvider('${provider.id}')">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  `;
}

function _renderDiagnosticsContent(providers) {
  const allDiag = window.AIProviderDiagnostics ? AIProviderDiagnostics.getAll() : {};
  if (Object.keys(allDiag).length === 0) {
    return `<div class="empty-state"><i class="fas fa-stethoscope"></i><p>No diagnostic data yet. Run tests or use AI.</p></div>`;
  }

  return `
    <div class="diagnostics-container">
      ${providers.map(p => {
        const d = allDiag[p.id];
        if (!d) return '';
        const avgLatency = d.requestCount > 0 ? Math.round(d.totalLatency / d.requestCount) : 0;
        const successRate = d.requestCount > 0 ? Math.round(((d.requestCount - d.errorCount) / d.requestCount) * 100) : 0;
        const statusDisp = window.AIProviderValidator ? AIProviderValidator.getStatusDisplay(d.lastStatus || 'untested') : { label: 'Unknown', color: '#6b7280', icon: 'fa-circle' };

        return `
          <div class="diag-card">
            <div class="diag-header">
              <div class="diag-provider">
                <i class="fas ${p.icon || 'fa-robot'}" style="color:${p.color || '#6c63ff'}"></i>
                <strong>${_escHtml(p.name)}</strong>
              </div>
              <span class="provider-status-badge" style="color:${statusDisp.color}">
                <i class="fas ${statusDisp.icon}"></i> ${statusDisp.label}
              </span>
            </div>
            <div class="diag-stats-grid">
              <div class="diag-stat">
                <span class="diag-stat-label">${t('ai.settings.latency')}</span>
                <span class="diag-stat-value">${avgLatency}ms</span>
              </div>
              <div class="diag-stat">
                <span class="diag-stat-label">${t('ai.settings.requestCount')}</span>
                <span class="diag-stat-value">${d.requestCount || 0}</span>
              </div>
              <div class="diag-stat">
                <span class="diag-stat-label">${t('ai.settings.errorCount')}</span>
                <span class="diag-stat-value" style="color:${d.errorCount > 0 ? '#ef4444' : '#22c55e'}">${d.errorCount || 0}</span>
              </div>
              <div class="diag-stat">
                <span class="diag-stat-label">${t('ai.settings.tokensUsed')}</span>
                <span class="diag-stat-value">${d.totalTokens || 0}</span>
              </div>
              <div class="diag-stat">
                <span class="diag-stat-label">Success Rate</span>
                <span class="diag-stat-value" style="color:${successRate > 80 ? '#22c55e' : successRate > 50 ? '#f59e0b' : '#ef4444'}">${successRate}%</span>
              </div>
            </div>
            ${d.lastResponse ? `<div class="diag-last"><i class="fas fa-check-circle" style="color:#22c55e"></i> ${t('ai.settings.lastResponse')}: ${new Date(d.lastResponse).toLocaleString()}</div>` : ''}
            ${d.lastError ? `<div class="diag-last error"><i class="fas fa-exclamation-triangle" style="color:#ef4444"></i> ${t('ai.settings.lastError')}: ${_escHtml(d.lastError.message || '')}</div>` : ''}
          </div>
        `;
      }).join('')}
      <button class="btn-secondary" onclick="AIProviderDiagnostics.clear();renderAISettingsPage()">
        <i class="fas fa-trash"></i> Clear All Diagnostics
      </button>
    </div>
  `;
}

function _renderDebuggerContent(logs) {
  // Register callback for live updates
  window._aiDebuggerUpdateCallback = () => {
    const debugTab = document.getElementById('settingsTab_debugger');
    if (debugTab && debugTab.classList.contains('active')) {
      const newLogs = window.AIRequestLogger ? AIRequestLogger.getAll() : [];
      const list = document.getElementById('debuggerLogList');
      if (list) list.innerHTML = _renderDebuggerLogs(newLogs);
    }
  };

  return `
    <div class="debugger-container">
      <div class="debugger-toolbar">
        <span class="debugger-count">${logs.length} ${logs.length === 1 ? 'request' : 'requests'}</span>
        <button class="btn-xs btn-danger" onclick="AIRequestLogger.clear();renderAISettingsPage()">
          <i class="fas fa-trash"></i> ${t('ai.settings.clearLogs')}
        </button>
      </div>
      ${logs.length === 0 ?
        `<div class="empty-state"><i class="fas fa-bug"></i><p>${t('ai.settings.noLogs')}</p></div>` :
        `<div class="debugger-log-list" id="debuggerLogList">${_renderDebuggerLogs(logs)}</div>`
      }
    </div>
  `;
}

function _renderDebuggerLogs(logs) {
  return logs.map(log => {
    const statusColor = log.httpStatus >= 200 && log.httpStatus < 300 ? '#22c55e' :
                       log.httpStatus === 0 ? '#6b7280' : '#ef4444';
    const timeStr = new Date(log.timestamp).toLocaleTimeString();
    return `
      <div class="debug-log-entry ${log.error ? 'has-error' : ''}">
        <div class="debug-log-header" onclick="this.parentElement.classList.toggle('expanded')">
          <span class="debug-status" style="color:${statusColor}">${log.httpStatus || '—'}</span>
          <span class="debug-type badge-${log.type}">${(log.type || 'req').toUpperCase()}</span>
          <span class="debug-provider">${_escHtml(log.providerName || log.providerId || 'Unknown')}</span>
          <span class="debug-model">${_escHtml(log.modelId || '—')}</span>
          <span class="debug-time">${log.responseTime ? log.responseTime + 'ms' : '—'}</span>
          <span class="debug-timestamp">${timeStr}</span>
          <i class="fas fa-chevron-down debug-chevron"></i>
        </div>
        <div class="debug-log-body">
          <div class="debug-section">
            <span class="debug-section-label">URL</span>
            <code>${_escHtml(log.url || '—')}</code>
          </div>
          <div class="debug-section">
            <span class="debug-section-label">Payload</span>
            <pre class="debug-pre">${_escHtml(JSON.stringify(log.payload || {}, null, 2))}</pre>
          </div>
          <div class="debug-section">
            <span class="debug-section-label">Response</span>
            <pre class="debug-pre">${_escHtml(JSON.stringify(log.response || log.error || {}, null, 2))}</pre>
          </div>
          ${log.error ? `<div class="debug-section error"><span class="debug-section-label">Error</span><code>${_escHtml(log.error)}</code></div>` : ''}
        </div>
      </div>
    `;
  }).join('');
}

function switchSettingsTab(event, tabName) {
  document.querySelectorAll('.ai-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.ai-tab-content').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');
  const content = document.getElementById('settingsTab_' + tabName);
  if (content) content.classList.add('active');
}

async function testProviderConnection(providerId) {
  const provider = AIProviders.getById(providerId);
  if (!provider) return;

  const btn = document.getElementById(`testBtn_${providerId}`);
  if (btn) {
    btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> ${t('validation.testing')}`;
    btn.disabled = true;
  }

  const result = await AIProviderValidator.testConnection(provider);

  // Update provider status in storage
  const providers = AIProviders.getAll();
  const idx = providers.findIndex(p => p.id === providerId);
  if (idx !== -1) {
    providers[idx].connectionStatus = result.status;
    providers[idx].lastTested = new Date().toISOString();
    localStorage.setItem('murad_ai_providers', JSON.stringify(providers));
  }

  if (btn) {
    const disp = AIProviderValidator.getStatusDisplay(result.status);
    btn.innerHTML = `<i class="fas ${disp.icon}"></i> ${disp.label}`;
    btn.style.color = disp.color;
    btn.disabled = false;
    setTimeout(() => {
      btn.innerHTML = `<i class="fas fa-plug"></i> ${t('ai.settings.testConnection')}`;
      btn.style.color = '';
    }, 3000);
  }

  showToast(result.message, result.status === 'connected' ? 'success' : 'error');

  // Update card status
  const card = document.querySelector(`[data-provider-id="${providerId}"]`);
  if (card) {
    card.className = `provider-card ${AIProviders.getActiveProvider()?.id === providerId ? 'active' : ''} status-${result.status}`;
    const statusEl = card.querySelector('.provider-status');
    if (statusEl) {
      const disp = AIProviderValidator.getStatusDisplay(result.status);
      statusEl.style.color = disp.color;
      statusEl.innerHTML = `<i class="fas ${disp.icon}"></i> <span>${disp.label}</span>`;
    }
  }
}

/* ============================================================
   PHASE 6 — ENHANCED AI ANALYTICS
   ============================================================ */

function renderAIAnalyticsPageEnhanced() {
  const container = document.getElementById('page-ai-analytics');
  if (!container) return;

  const stats = window.AIContextEngine ? AIContextEngine.build().stats : (window.AIAgent ? AIAgent.getStats() : {});
  const memories = window.AIMemory ? AIMemory.getAll() : [];
  const insights = window.AIAnalytics ? AIAnalytics.generateInsights() : [];

  const perf = stats.performanceScore || 0;
  const prod = stats.productivityScore || 0;
  const focus = stats.focusScore || 0;

  container.innerHTML = `
    <div class="ai-analytics-layout">
      <div class="ai-page-header">
        <h1><i class="fas fa-chart-bar"></i> <span>${t('ai.analytics.title')}</span></h1>
        <button class="btn-primary" onclick="generateAIAnalysisReport()">
          <i class="fas fa-file-alt"></i> ${t('ai.analytics.generateReport')}
        </button>
      </div>

      <!-- Score Cards -->
      <div class="analytics-scores">
        ${_renderScoreCard('performance', perf, t('ai.analytics.performance'), 'fa-chart-line', '#6c63ff')}
        ${_renderScoreCard('productivity', prod, t('ai.analytics.productivity'), 'fa-tasks', '#22c55e')}
        ${_renderScoreCard('focus', focus, t('ai.analytics.focus'), 'fa-crosshairs', '#3b82f6')}
        ${_renderBurnoutCard(stats.burnoutRisk || 'low')}
      </div>

      <!-- Subject Analysis -->
      <div class="analytics-section">
        <h2><i class="fas fa-book"></i> Subject Analysis</h2>
        <div class="subject-analysis">
          <div class="subject-card best">
            <i class="fas fa-trophy" style="color:#f59e0b"></i>
            <div>
              <span class="subject-label">${t('ai.analytics.bestSubject')}</span>
              <strong>${stats.bestSubject || '—'}</strong>
            </div>
          </div>
          <div class="subject-card weak">
            <i class="fas fa-chart-line fa-flip-vertical" style="color:#ef4444"></i>
            <div>
              <span class="subject-label">${t('ai.analytics.weakSubject')}</span>
              <strong>${stats.weakSubject || '—'}</strong>
            </div>
          </div>
          <div class="subject-card completion">
            <i class="fas fa-check-circle" style="color:#22c55e"></i>
            <div>
              <span class="subject-label">${t('ai.analytics.completionRate')}</span>
              <strong>${stats.completionRate || 0}%</strong>
            </div>
          </div>
          <div class="subject-card missed">
            <i class="fas fa-calendar-times" style="color:#ef4444"></i>
            <div>
              <span class="subject-label">${t('ai.analytics.missedSessions')}</span>
              <strong>${(stats.totalBlocks || 0) - (stats.completedBlocks || 0)}</strong>
            </div>
          </div>
        </div>
      </div>

      <!-- Subject Time Breakdown -->
      ${stats.subjectTimes && Object.keys(stats.subjectTimes).length > 0 ? `
      <div class="analytics-section">
        <h2><i class="fas fa-clock"></i> Time per Subject</h2>
        <div class="subject-bars">
          ${_renderSubjectBars(stats.subjectTimes)}
        </div>
      </div>` : ''}

      <!-- AI Recommendations -->
      <div class="analytics-section">
        <h2><i class="fas fa-lightbulb"></i> ${t('ai.analytics.recommendations')}</h2>
        <div class="recommendations-list">
          ${_renderRecommendations(stats, insights)}
        </div>
      </div>

      <!-- Memory Section -->
      <div class="analytics-section">
        <div class="section-header">
          <h2><i class="fas fa-brain"></i> ${t('ai.analytics.memory')}</h2>
          <div class="section-actions">
            <button class="btn-secondary" onclick="showAddMemoryDialog()">
              <i class="fas fa-plus"></i> ${t('ai.analytics.addMemory')}
            </button>
            <button class="btn-danger-ghost" onclick="clearAIMemory()">
              <i class="fas fa-trash"></i> ${t('ai.analytics.clearMemory')}
            </button>
          </div>
        </div>
        <div class="memory-grid" id="memoryGrid">
          ${_renderMemoryItems(memories)}
        </div>
      </div>
    </div>
  `;
}

function _renderScoreCard(type, score, label, icon, color) {
  const level = score >= 80 ? t('ai.analytics.excellent') : score >= 60 ? t('ai.analytics.high') : score >= 40 ? t('ai.analytics.medium') : t('ai.analytics.low');
  const levelColor = score >= 80 ? '#22c55e' : score >= 60 ? '#3b82f6' : score >= 40 ? '#f59e0b' : '#ef4444';
  return `
    <div class="score-card">
      <div class="score-icon" style="color:${color}"><i class="fas ${icon}"></i></div>
      <div class="score-info">
        <span class="score-label">${label}</span>
        <div class="score-value">${score}<span>/100</span></div>
        <span class="score-level" style="color:${levelColor}">${level}</span>
      </div>
      <div class="score-ring">
        <svg viewBox="0 0 36 36">
          <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
            fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="3"/>
          <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
            fill="none" stroke="${color}" stroke-width="3"
            stroke-dasharray="${score}, 100" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  `;
}

function _renderBurnoutCard(risk) {
  const colors = { low: '#22c55e', medium: '#f59e0b', high: '#ef4444' };
  const icons = { low: 'fa-smile', medium: 'fa-meh', high: 'fa-exclamation-triangle' };
  const color = colors[risk] || colors.low;
  return `
    <div class="score-card burnout">
      <div class="score-icon" style="color:${color}"><i class="fas ${icons[risk] || 'fa-smile'}"></i></div>
      <div class="score-info">
        <span class="score-label">${t('ai.analytics.burnout')}</span>
        <div class="score-value" style="color:${color}; font-size:18px">${risk.toUpperCase()}</div>
      </div>
    </div>
  `;
}

function _renderSubjectBars(subjectTimes) {
  const total = Object.values(subjectTimes).reduce((a, b) => a + b, 0) || 1;
  const sorted = Object.entries(subjectTimes).sort(([, a], [, b]) => b - a);
  const colors = ['#6c63ff', '#22c55e', '#3b82f6', '#f59e0b', '#ef4444', '#ec4899'];

  return sorted.map(([subject, minutes], i) => {
    const pct = Math.round((minutes / total) * 100);
    return `
      <div class="subject-bar-item">
        <div class="subject-bar-label">
          <span>${_escHtml(subject)}</span>
          <span>${minutes}min (${pct}%)</span>
        </div>
        <div class="subject-bar-track">
          <div class="subject-bar-fill" style="width:${pct}%;background:${colors[i % colors.length]}"></div>
        </div>
      </div>
    `;
  }).join('');
}

function _renderRecommendations(stats, insights) {
  const recs = [];

  if (stats.completionRate < 50) {
    recs.push({ icon: 'fa-exclamation-triangle', color: '#f59e0b', text: 'Your completion rate is low. Consider reducing daily blocks or extending session durations.' });
  }
  if (stats.burnoutRisk === 'high') {
    recs.push({ icon: 'fa-heart', color: '#ef4444', text: 'High burnout risk detected. Add more breaks and reduce pressure on yourself.' });
  }
  if (stats.focusScore < 60) {
    recs.push({ icon: 'fa-crosshairs', color: '#3b82f6', text: 'Focus score is below average. Try the Pomodoro technique with 25-minute blocks.' });
  }
  if (stats.bestSubject && stats.weakSubject && stats.bestSubject !== stats.weakSubject) {
    recs.push({ icon: 'fa-balance-scale', color: '#22c55e', text: `You're strong in ${stats.bestSubject}. Allocate more time to ${stats.weakSubject} to balance your skills.` });
  }
  if (stats.completionRate >= 80) {
    recs.push({ icon: 'fa-trophy', color: '#f59e0b', text: 'Excellent completion rate! Consider increasing difficulty or adding new challenging blocks.' });
  }

  // Add insight-based recommendations
  if (insights && insights.length > 0) {
    insights.slice(0, 2).forEach(insight => {
      recs.push({ icon: 'fa-lightbulb', color: '#6c63ff', text: typeof insight === 'string' ? insight : insight.text || insight });
    });
  }

  if (recs.length === 0) {
    recs.push({ icon: 'fa-info-circle', color: '#6c63ff', text: 'No data available yet. Start tracking your study sessions to get personalized recommendations.' });
  }

  return recs.map(r => `
    <div class="recommendation-item">
      <i class="fas ${r.icon}" style="color:${r.color}"></i>
      <p>${_escHtml(r.text)}</p>
    </div>
  `).join('');
}

function _renderMemoryItems(memories) {
  if (!memories.length) {
    return `<div class="memory-empty"><i class="fas fa-brain"></i><p>No memories stored yet. AI will automatically remember important insights.</p></div>`;
  }
  return memories.map(m => `
    <div class="memory-item">
      <div class="memory-content">${_escHtml(m.content || m)}</div>
      <div class="memory-meta">
        <span class="memory-category">${_escHtml(m.category || 'general')}</span>
        ${m.createdAt ? `<span class="memory-time">${new Date(m.createdAt).toLocaleDateString()}</span>` : ''}
        <button class="memory-delete" onclick="deleteMemoryItem('${m.id}')"><i class="fas fa-times"></i></button>
      </div>
    </div>
  `).join('');
}

function showAddMemoryDialog() {
  const content = prompt('Enter memory to store:');
  if (content && content.trim()) {
    if (window.AIMemory) {
      AIMemory.add({ content: content.trim(), category: 'manual', source: 'user' });
    }
    renderAIAnalyticsPage();
    showToast(t('toast.added'), 'success');
  }
}

function deleteMemoryItem(id) {
  if (window.AIMemory) {
    AIMemory.remove(id);
    renderAIAnalyticsPage();
  }
}

/* ============================================================
   PHASE 7 — ENHANCED AUTOMATION BUILDER
   ============================================================ */

function renderAIAutomationPageEnhanced() {
  const container = document.getElementById('page-ai-automation');
  if (!container) return;

  const automations = window.AIAutomations ? AIAutomations.getAll() : [];

  container.innerHTML = `
    <div class="ai-auto-layout">
      <div class="ai-page-header">
        <h1><i class="fas fa-robot"></i> <span>${t('ai.auto.title')}</span></h1>
        <button class="btn-primary" onclick="openAddAutomationModal()">
          <i class="fas fa-plus"></i> ${t('ai.auto.new')}
        </button>
      </div>

      <!-- Automation Cards -->
      ${automations.length === 0 ?
        `<div class="empty-state">
          <i class="fas fa-robot"></i>
          <h3>${t('ai.auto.noAutomations')}</h3>
          <p>Create automations to automate repetitive tasks</p>
          <button class="btn-primary" onclick="openAddAutomationModal()">
            <i class="fas fa-plus"></i> ${t('ai.auto.new')}
          </button>
        </div>` :
        `<div class="automation-list">
          ${automations.map(a => _renderAutomationCard(a)).join('')}
        </div>`
      }

      <!-- Templates Section -->
      <div class="templates-section">
        <h2><i class="fas fa-magic"></i> ${t('ai.auto.templates')}</h2>
        <div class="templates-grid">
          ${_renderAutomationTemplates()}
        </div>
      </div>

      <!-- Modal -->
      <div class="ai-modal" id="automationModal" style="display:none">
        <div class="ai-modal-overlay" onclick="closeAutomationModal()"></div>
        <div class="ai-modal-content" id="automationModalContent"></div>
      </div>
    </div>
  `;
}

function _renderAutomationCard(automation) {
  const triggerLabel = t(`ai.auto.trigger.${automation.trigger}`) || automation.trigger;
  const actionLabel = t(`ai.auto.action.${automation.action}`) || automation.action;

  return `
    <div class="automation-card ${automation.enabled ? 'enabled' : 'disabled'}">
      <div class="auto-card-header">
        <div class="auto-card-title">
          <i class="fas fa-robot"></i>
          <strong>${_escHtml(automation.name)}</strong>
        </div>
        <label class="toggle-switch">
          <input type="checkbox" ${automation.enabled ? 'checked' : ''} 
                 onchange="toggleAutomation('${automation.id}', this.checked)">
          <span class="toggle-slider"></span>
        </label>
      </div>

      <div class="auto-rule-visual">
        <div class="auto-rule-block trigger">
          <span class="auto-rule-label">${t('ai.auto.if')}</span>
          <span class="auto-rule-value"><i class="fas fa-bolt"></i> ${triggerLabel}</span>
        </div>
        ${automation.condition ? `
        <div class="auto-rule-connector">AND</div>
        <div class="auto-rule-block condition">
          <span class="auto-rule-label">${t('ai.auto.condition')}</span>
          <span class="auto-rule-value"><i class="fas fa-filter"></i> ${_escHtml(automation.condition)}</span>
        </div>` : ''}
        <div class="auto-rule-connector"><i class="fas fa-arrow-down"></i></div>
        <div class="auto-rule-block action">
          <span class="auto-rule-label">${t('ai.auto.then')}</span>
          <span class="auto-rule-value"><i class="fas fa-play"></i> ${actionLabel}</span>
        </div>
      </div>

      <div class="auto-card-meta">
        <span><i class="fas fa-clock"></i> ${t('ai.auto.lastRun')}: ${automation.lastRun ? new Date(automation.lastRun).toLocaleDateString() : t('ai.auto.never')}</span>
        ${automation.runCount ? `<span><i class="fas fa-play-circle"></i> Run ${automation.runCount}x</span>` : ''}
      </div>

      <div class="auto-card-actions">
        <button class="btn-xs btn-primary" onclick="runAutomation('${automation.id}')">
          <i class="fas fa-play"></i> ${t('ai.auto.run')}
        </button>
        <button class="btn-xs btn-danger" onclick="deleteAutomation('${automation.id}')">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  `;
}

function _renderAutomationTemplates() {
  const templates = [
    {
      name: 'Session Streak',
      description: 'Increase streak when session completes',
      trigger: 'session_complete',
      action: 'increase_streak',
      icon: 'fa-fire',
      color: '#f59e0b'
    },
    {
      name: 'Inactivity Alert',
      description: 'Send reminder after 3 days inactive',
      trigger: 'inactivity',
      action: 'send_reminder',
      condition: 'days >= 3',
      icon: 'fa-bell',
      color: '#ef4444'
    },
    {
      name: 'Weekly Report',
      description: 'Generate weekly AI report every Sunday',
      trigger: 'weekly_start',
      action: 'generate_report',
      icon: 'fa-file-alt',
      color: '#6c63ff'
    },
    {
      name: 'Daily Briefing',
      description: 'Get AI daily briefing each morning',
      trigger: 'daily_start',
      action: 'send_notification',
      icon: 'fa-sun',
      color: '#22c55e'
    }
  ];

  return templates.map(tmpl => `
    <div class="template-card" onclick="applyAutomationTemplate(${JSON.stringify(tmpl).replace(/"/g, '&quot;')})">
      <div class="template-icon" style="color:${tmpl.color}"><i class="fas ${tmpl.icon}"></i></div>
      <div class="template-info">
        <strong>${_escHtml(tmpl.name)}</strong>
        <p>${_escHtml(tmpl.description)}</p>
      </div>
      <div class="template-rule">
        <span class="rule-trigger">${t(`ai.auto.trigger.${tmpl.trigger}`) || tmpl.trigger}</span>
        <i class="fas fa-arrow-right"></i>
        <span class="rule-action">${t(`ai.auto.action.${tmpl.action}`) || tmpl.action}</span>
      </div>
    </div>
  `).join('');
}

function applyAutomationTemplate(template) {
  if (!window.AIAutomations) return;
  AIAutomations.save({
    name: template.name,
    trigger: template.trigger,
    action: template.action,
    condition: template.condition || '',
    enabled: true
  });
  renderAIAutomationPage();
  showToast(t('toast.added'), 'success');
}

function openAddAutomationModal() {
  const modal = document.getElementById('automationModal');
  const content = document.getElementById('automationModalContent');
  if (!modal || !content) return;

  const triggers = ['session_complete', 'streak_milestone', 'inactivity', 'score_drop', 'weekly_start', 'daily_start', 'manual'];
  const actions = ['send_reminder', 'create_schedule', 'generate_report', 'increase_streak', 'suggest_review', 'send_notification'];

  content.innerHTML = `
    <div class="modal-header">
      <h2>${t('ai.auto.new')}</h2>
      <button onclick="closeAutomationModal()" class="modal-close-btn"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>${t('ai.auto.name')}</label>
        <input type="text" id="autoName" placeholder="${t('ai.auto.name')}..." class="form-input">
      </div>
      <div class="auto-rule-builder">
        <div class="rule-row">
          <div class="rule-label">${t('ai.auto.if')}</div>
          <select id="autoTrigger" class="form-select">
            ${triggers.map(tr => `<option value="${tr}">${t(`ai.auto.trigger.${tr}`) || tr}</option>`).join('')}
          </select>
        </div>
        <div class="rule-row">
          <div class="rule-label">${t('ai.auto.condition')} (opt)</div>
          <input type="text" id="autoCondition" placeholder="e.g. days >= 3" class="form-input">
        </div>
        <div class="rule-row">
          <div class="rule-label">${t('ai.auto.then')}</div>
          <select id="autoAction" class="form-select">
            ${actions.map(ac => `<option value="${ac}">${t(`ai.auto.action.${ac}`) || ac}</option>`).join('')}
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="toggle-label">
          <input type="checkbox" id="autoEnabled" checked>
          <span>${t('ai.auto.enabled')}</span>
        </label>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" onclick="closeAutomationModal()">${t('btn.cancel')}</button>
      <button class="btn-primary" onclick="saveNewAutomation()">${t('btn.save')}</button>
    </div>
  `;

  modal.style.display = 'flex';
}

function closeAutomationModal() {
  const modal = document.getElementById('automationModal');
  if (modal) modal.style.display = 'none';
}

function saveNewAutomation() {
  const name = document.getElementById('autoName')?.value?.trim();
  const trigger = document.getElementById('autoTrigger')?.value;
  const condition = document.getElementById('autoCondition')?.value?.trim();
  const action = document.getElementById('autoAction')?.value;
  const enabled = document.getElementById('autoEnabled')?.checked;

  if (!name || !trigger || !action) {
    showToast(t('validation.fillRequired'), 'error');
    return;
  }

  if (window.AIAutomations) {
    AIAutomations.save({ name, trigger, condition, action, enabled });
  }
  closeAutomationModal();
  renderAIAutomationPage();
  showToast(t('toast.added'), 'success');
}

function toggleAutomation(id, enabled) {
  if (!window.AIAutomations) return;
  const automations = AIAutomations.getAll();
  const a = automations.find(a => a.id === id);
  if (a) {
    a.enabled = enabled;
    AIAutomations.save(a);
  }
}

/* ============================================================
   PHASE 8 — MULTIPLE AI PERSONALITY PROFILES
   ============================================================ */

function renderAIPersonalityPageEnhanced() {
  const container = document.getElementById('page-ai-personality');
  if (!container) return;

  const profiles = _getPersonalityProfiles();
  const activeId = localStorage.getItem('murad_ai_active_profile') || 'default';

  container.innerHTML = `
    <div class="ai-personality-layout">
      <div class="ai-page-header">
        <h1><i class="fas fa-user-cog"></i> <span>${t('ai.personality.title')}</span></h1>
        <button class="btn-primary" onclick="openAddProfileModal()">
          <i class="fas fa-plus"></i> ${t('ai.personality.addProfile')}
        </button>
      </div>

      <!-- Profiles List -->
      <div class="profiles-section">
        <h2>${t('ai.personality.profiles')}</h2>
        <div class="profiles-grid" id="profilesGrid">
          ${profiles.map(p => _renderProfileCard(p, p.id === activeId)).join('')}
        </div>
      </div>

      <!-- Active Profile Editor -->
      <div class="active-profile-editor" id="activeProfileEditor">
        ${_renderProfileEditor(profiles.find(p => p.id === activeId) || profiles[0])}
      </div>

      <!-- Profile Modal -->
      <div class="ai-modal" id="profileModal" style="display:none">
        <div class="ai-modal-overlay" onclick="closeProfileModal()"></div>
        <div class="ai-modal-content" id="profileModalContent"></div>
      </div>
    </div>
  `;
}

function _getPersonalityProfiles() {
  const stored = localStorage.getItem('murad_ai_profiles');
  if (stored) {
    try { return JSON.parse(stored); } catch (e) { /* fallback */ }
  }
  // Default profiles
  return [
    {
      id: 'default',
      name: 'Murad AI',
      assistantName: 'Murad AI',
      tone: 'friendly',
      language: 'ar',
      teachingStyle: 'direct',
      responseLength: 'medium',
      systemPrompt: '',
      behaviourRules: ['Always respond in the user\'s selected language', 'Be concise and helpful']
    },
    {
      id: 'strict',
      name: 'Study Coach',
      assistantName: 'Coach',
      tone: 'strict',
      language: 'en',
      teachingStyle: 'socratic',
      responseLength: 'long',
      systemPrompt: 'You are a strict study coach who holds the user accountable.',
      behaviourRules: ['Never accept excuses', 'Always push the user to do better']
    },
    {
      id: 'motivational',
      name: 'Motivator',
      assistantName: 'Spark',
      tone: 'motivational',
      language: 'en',
      teachingStyle: 'storytelling',
      responseLength: 'medium',
      systemPrompt: 'You are an energetic, motivating assistant who inspires action.',
      behaviourRules: ['Always end with an encouraging note', 'Use emojis sparingly']
    }
  ];
}

function _savePersonalityProfiles(profiles) {
  localStorage.setItem('murad_ai_profiles', JSON.stringify(profiles));
}

function _renderProfileCard(profile, isActive) {
  const toneColors = { friendly: '#22c55e', professional: '#3b82f6', motivational: '#f59e0b', strict: '#ef4444', casual: '#6c63ff' };
  const color = toneColors[profile.tone] || '#6c63ff';

  return `
    <div class="profile-card ${isActive ? 'active' : ''}" onclick="selectProfile('${profile.id}')">
      <div class="profile-avatar" style="background:${color}22;color:${color}">
        <i class="fas fa-user-circle"></i>
      </div>
      <div class="profile-info">
        <strong>${_escHtml(profile.name)}</strong>
        <span class="profile-tone" style="color:${color}">${t(`ai.personality.tone.${profile.tone}`) || profile.tone}</span>
        <span class="profile-style">${t(`ai.personality.style.${profile.teachingStyle}`) || profile.teachingStyle}</span>
      </div>
      ${isActive ? `<span class="profile-active-badge"><i class="fas fa-check"></i></span>` : ''}
      ${profile.id !== 'default' ? `
      <button class="profile-delete-btn" onclick="event.stopPropagation();deleteProfile('${profile.id}')">
        <i class="fas fa-trash"></i>
      </button>` : ''}
    </div>
  `;
}

function _renderProfileEditor(profile) {
  if (!profile) return '';
  const tones = ['friendly', 'professional', 'motivational', 'strict', 'casual'];
  const styles = ['socratic', 'direct', 'storytelling', 'examples'];
  const lengths = ['short', 'medium', 'long'];
  const langs = ['ar', 'en', 'id'];

  return `
    <h2><i class="fas fa-edit"></i> Edit: ${_escHtml(profile.name)}</h2>
    <div class="profile-editor-form">
      <div class="form-row">
        <div class="form-group">
          <label>${t('ai.personality.name')}</label>
          <input type="text" id="profileName" value="${_escHtml(profile.name)}" class="form-input">
        </div>
        <div class="form-group">
          <label>${t('ai.personality.assistantName')}</label>
          <input type="text" id="profileAssistantName" value="${_escHtml(profile.assistantName)}" class="form-input">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>${t('ai.personality.tone')}</label>
          <div class="radio-group">
            ${tones.map(tone => `
              <label class="radio-option ${profile.tone === tone ? 'active' : ''}">
                <input type="radio" name="profileTone" value="${tone}" ${profile.tone === tone ? 'checked' : ''}
                       onchange="document.querySelectorAll('.radio-option').forEach(o=>o.classList.remove('active'));this.parentElement.classList.add('active')">
                ${t(`ai.personality.tone.${tone}`) || tone}
              </label>
            `).join('')}
          </div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>${t('ai.personality.language')}</label>
          <select id="profileLanguage" class="form-select">
            ${langs.map(l => `<option value="${l}" ${profile.language === l ? 'selected' : ''}>${l.toUpperCase()}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label>${t('ai.personality.teachingStyle')}</label>
          <select id="profileStyle" class="form-select">
            ${styles.map(s => `<option value="${s}" ${profile.teachingStyle === s ? 'selected' : ''}>${t(`ai.personality.style.${s}`) || s}</option>`).join('')}
          </select>
        </div>
        <div class="form-group">
          <label>${t('ai.personality.responseLength')}</label>
          <select id="profileLength" class="form-select">
            ${lengths.map(l => `<option value="${l}" ${profile.responseLength === l ? 'selected' : ''}>${t(`ai.personality.length.${l}`) || l}</option>`).join('')}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>${t('ai.personality.systemPrompt')}</label>
        <textarea id="profileSystemPrompt" class="form-textarea" rows="3">${_escHtml(profile.systemPrompt || '')}</textarea>
      </div>

      <div class="form-group">
        <label>${t('ai.personality.behaviourRules')}</label>
        <div id="behaviourRulesContainer">
          ${(profile.behaviourRules || []).map((rule, i) => `
            <div class="rule-item" id="rule_${i}">
              <input type="text" class="form-input rule-input" value="${_escHtml(rule)}" placeholder="Rule...">
              <button class="btn-xs btn-danger" onclick="removeBehaviourRule(${i})"><i class="fas fa-times"></i></button>
            </div>
          `).join('')}
        </div>
        <button class="btn-secondary btn-sm" onclick="addBehaviourRule()">
          <i class="fas fa-plus"></i> ${t('ai.personality.addRule')}
        </button>
      </div>

      <div class="form-actions">
        <button class="btn-primary" onclick="saveActiveProfile('${profile.id}')">
          <i class="fas fa-save"></i> ${t('ai.personality.save')}
        </button>
        <button class="btn-secondary" onclick="renderAIPersonalityPage()">
          <i class="fas fa-undo"></i> ${t('ai.personality.reset')}
        </button>
      </div>
    </div>
  `;
}

function selectProfile(profileId) {
  localStorage.setItem('murad_ai_active_profile', profileId);
  const profiles = _getPersonalityProfiles();
  const profile = profiles.find(p => p.id === profileId);
  if (profile && window.AIPersonality) {
    AIPersonality.save(profile);
  }
  renderAIPersonalityPage();
  showToast(t('ai.personality.active') + ': ' + (profiles.find(p => p.id === profileId)?.name || profileId), 'success');
}

function saveActiveProfile(profileId) {
  const profiles = _getPersonalityProfiles();
  const idx = profiles.findIndex(p => p.id === profileId);
  if (idx === -1) return;

  const tone = document.querySelector('[name="profileTone"]:checked')?.value || profiles[idx].tone;
  const rules = Array.from(document.querySelectorAll('.rule-input')).map(i => i.value.trim()).filter(Boolean);

  profiles[idx] = {
    ...profiles[idx],
    name: document.getElementById('profileName')?.value || profiles[idx].name,
    assistantName: document.getElementById('profileAssistantName')?.value || profiles[idx].assistantName,
    tone,
    language: document.getElementById('profileLanguage')?.value || profiles[idx].language,
    teachingStyle: document.getElementById('profileStyle')?.value || profiles[idx].teachingStyle,
    responseLength: document.getElementById('profileLength')?.value || profiles[idx].responseLength,
    systemPrompt: document.getElementById('profileSystemPrompt')?.value || '',
    behaviourRules: rules
  };

  _savePersonalityProfiles(profiles);
  if (window.AIPersonality) AIPersonality.save(profiles[idx]);
  showToast(t('toast.saved'), 'success');
  renderAIPersonalityPage();
}

function addBehaviourRule() {
  const container = document.getElementById('behaviourRulesContainer');
  if (!container) return;
  const i = container.children.length;
  const div = document.createElement('div');
  div.className = 'rule-item';
  div.id = `rule_${i}`;
  div.innerHTML = `
    <input type="text" class="form-input rule-input" placeholder="Rule...">
    <button class="btn-xs btn-danger" onclick="removeBehaviourRule(${i})"><i class="fas fa-times"></i></button>
  `;
  container.appendChild(div);
}

function removeBehaviourRule(index) {
  const rule = document.getElementById(`rule_${index}`);
  if (rule) rule.remove();
}

function openAddProfileModal() {
  const modal = document.getElementById('profileModal');
  const content = document.getElementById('profileModalContent');
  if (!modal || !content) return;

  content.innerHTML = `
    <div class="modal-header">
      <h2>${t('ai.personality.addProfile')}</h2>
      <button onclick="closeProfileModal()" class="modal-close-btn"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>${t('ai.personality.name')}</label>
        <input type="text" id="newProfileName" class="form-input" placeholder="My Custom Profile">
      </div>
      <div class="form-group">
        <label>${t('ai.personality.assistantName')}</label>
        <input type="text" id="newProfileAssistantName" class="form-input" placeholder="AI Assistant">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" onclick="closeProfileModal()">${t('btn.cancel')}</button>
      <button class="btn-primary" onclick="createNewProfile()">${t('btn.add')}</button>
    </div>
  `;
  modal.style.display = 'flex';
}

function closeProfileModal() {
  const modal = document.getElementById('profileModal');
  if (modal) modal.style.display = 'none';
}

function createNewProfile() {
  const name = document.getElementById('newProfileName')?.value?.trim();
  const assistantName = document.getElementById('newProfileAssistantName')?.value?.trim();
  if (!name) { showToast(t('validation.fillRequired'), 'error'); return; }

  const profiles = _getPersonalityProfiles();
  profiles.push({
    id: 'profile_' + Date.now(),
    name,
    assistantName: assistantName || name,
    tone: 'friendly',
    language: getCurrentLang(),
    teachingStyle: 'direct',
    responseLength: 'medium',
    systemPrompt: '',
    behaviourRules: []
  });
  _savePersonalityProfiles(profiles);
  closeProfileModal();
  renderAIPersonalityPage();
  showToast(t('toast.added'), 'success');
}

function deleteProfile(profileId) {
  if (profileId === 'default') { showToast('Cannot delete default profile', 'error'); return; }
  if (!confirm('Delete this profile?')) return;
  const profiles = _getPersonalityProfiles().filter(p => p.id !== profileId);
  _savePersonalityProfiles(profiles);
  if (localStorage.getItem('murad_ai_active_profile') === profileId) {
    localStorage.setItem('murad_ai_active_profile', 'default');
  }
  renderAIPersonalityPage();
}

/* ============================================================
   PHASE 9 — AI DASHBOARD WIDGET (Daily Intelligence Report)
   ============================================================ */

const AIDashboardWidget = {
  _reportKey: 'murad_ai_daily_report',
  _lastGeneratedKey: 'murad_ai_report_last_generated',

  async generate(force = false) {
    const today = new Date().toDateString();
    const lastGenerated = localStorage.getItem(this._lastGeneratedKey);

    if (!force && lastGenerated === today) {
      return this.getStored();
    }

    const provider = window.AIProviders ? AIProviders.getActiveProvider() : null;
    if (!provider || !provider.apiKey) {
      return this._generateLocalReport();
    }

    const context = window.AIContextEngine ? AIContextEngine.build() : {};
    const stats = context.stats || {};

    const prompt = `Generate a brief daily intelligence report for a student based on this data:
- Performance: ${stats.performanceScore || 0}%
- Productivity: ${stats.productivityScore || 0}%
- Completion Rate: ${stats.completionRate || 0}%
- Burnout Risk: ${stats.burnoutRisk || 'low'}
- Best Subject: ${stats.bestSubject || 'none'}
- Weakest Subject: ${stats.weakSubject || 'none'}

Return a JSON object with these keys:
{
  "todayAnalysis": "Brief 1-2 sentence analysis",
  "risks": ["risk 1", "risk 2"],
  "opportunities": ["opportunity 1", "opportunity 2"],
  "suggestedActions": ["action 1", "action 2", "action 3"],
  "motivation": "One motivational insight"
}
Keep each item very brief (max 1 sentence).`;

    try {
      const systemPrompt = window.AIContextEngine ? AIContextEngine.buildSystemPrompt(context) : 'You are a learning assistant.';
      let responseText = '';

      await new Promise((resolve, reject) => {
        AIChat.sendMessageStream(
          systemPrompt,
          [{ role: 'user', content: prompt }],
          (chunk) => { responseText += chunk; },
          resolve,
          reject
        );
      });

      // Extract JSON
      const jsonMatch = responseText.match(/\{[\s\S]*\}/);
      if (jsonMatch) {
        const report = JSON.parse(jsonMatch[0]);
        report.generatedAt = new Date().toISOString();
        report.aiGenerated = true;
        localStorage.setItem(this._reportKey, JSON.stringify(report));
        localStorage.setItem(this._lastGeneratedKey, today);
        return report;
      }
    } catch (e) {
      console.error('[AIDashboardWidget] Generation error:', e);
    }

    return this._generateLocalReport();
  },

  _generateLocalReport() {
    const stats = window.AIContextEngine ? AIContextEngine.build().stats : {};
    const score = stats.performanceScore || 0;

    const report = {
      todayAnalysis: score > 70
        ? 'Great performance today! You\'re on track with your study goals.'
        : score > 40
        ? 'Moderate performance. A few more focused sessions would help.'
        : 'Performance needs improvement. Consider reviewing your study schedule.',
      risks: [
        stats.burnoutRisk === 'high' ? 'High burnout risk - take breaks' : null,
        stats.completionRate < 50 ? 'Low completion rate' : null
      ].filter(Boolean),
      opportunities: [
        stats.bestSubject ? `Build on your strength in ${stats.bestSubject}` : 'Identify your strongest subject',
        'Use the AI assistant for personalized study plans'
      ],
      suggestedActions: [
        'Review today\'s schedule and prioritize key blocks',
        'Spend extra time on ' + (stats.weakSubject || 'weaker subjects'),
        'Take a 10-minute break between study sessions'
      ],
      motivation: 'Every study session is a step toward your goals. Keep going!',
      generatedAt: new Date().toISOString(),
      aiGenerated: false
    };

    localStorage.setItem(this._reportKey, JSON.stringify(report));
    localStorage.setItem(this._lastGeneratedKey, new Date().toDateString());
    return report;
  },

  getStored() {
    try {
      const raw = localStorage.getItem(this._reportKey);
      return raw ? JSON.parse(raw) : null;
    } catch (e) { return null; }
  },

  renderWidget(containerId, report) {
    const container = document.getElementById(containerId);
    if (!container) return;

    if (!report) {
      container.innerHTML = `
        <div class="ai-widget-card">
          <div class="ai-widget-header">
            <i class="fas fa-brain"></i>
            <h3>${t('ai.widget.title')}</h3>
            <button onclick="AIDashboardWidget.refreshWidget('${containerId}')" class="widget-refresh-btn">
              <i class="fas fa-sync"></i>
            </button>
          </div>
          <div class="ai-widget-generating">
            <i class="fas fa-spinner fa-spin"></i>
            <p>${t('ai.widget.generating')}</p>
          </div>
        </div>
      `;
      this.generate().then(r => this.renderWidget(containerId, r));
      return;
    }

    container.innerHTML = `
      <div class="ai-widget-card">
        <div class="ai-widget-header">
          <i class="fas fa-brain"></i>
          <h3>${t('ai.widget.title')}</h3>
          <div class="widget-header-actions">
            ${report.aiGenerated ? `<span class="ai-generated-badge"><i class="fas fa-robot"></i> AI</span>` : ''}
            <span class="widget-time">${new Date(report.generatedAt || Date.now()).toLocaleDateString()}</span>
            <button onclick="AIDashboardWidget.refreshWidget('${containerId}')" class="widget-refresh-btn" title="${t('ai.widget.refresh')}">
              <i class="fas fa-sync"></i>
            </button>
          </div>
        </div>

        <div class="widget-section">
          <div class="widget-section-title"><i class="fas fa-chart-line"></i> ${t('ai.widget.todayAnalysis')}</div>
          <p class="widget-text">${_escHtml(report.todayAnalysis || '')}</p>
        </div>

        ${report.risks && report.risks.length > 0 ? `
        <div class="widget-section">
          <div class="widget-section-title"><i class="fas fa-exclamation-triangle" style="color:#ef4444"></i> ${t('ai.widget.risks')}</div>
          <ul class="widget-list">
            ${report.risks.map(r => `<li>${_escHtml(r)}</li>`).join('')}
          </ul>
        </div>` : ''}

        ${report.opportunities && report.opportunities.length > 0 ? `
        <div class="widget-section">
          <div class="widget-section-title"><i class="fas fa-star" style="color:#f59e0b"></i> ${t('ai.widget.opportunities')}</div>
          <ul class="widget-list">
            ${report.opportunities.map(o => `<li>${_escHtml(o)}</li>`).join('')}
          </ul>
        </div>` : ''}

        <div class="widget-section">
          <div class="widget-section-title"><i class="fas fa-tasks" style="color:#22c55e"></i> ${t('ai.widget.suggestedActions')}</div>
          <ul class="widget-list actions">
            ${(report.suggestedActions || []).map((a, i) => `<li><span class="action-num">${i + 1}</span>${_escHtml(a)}</li>`).join('')}
          </ul>
        </div>

        ${report.motivation ? `
        <div class="widget-motivation">
          <i class="fas fa-quote-left"></i>
          <p>${_escHtml(report.motivation)}</p>
        </div>` : ''}
      </div>
    `;
  },

  async refreshWidget(containerId) {
    const container = document.getElementById(containerId);
    if (container) {
      container.innerHTML = `<div class="ai-widget-generating"><i class="fas fa-spinner fa-spin"></i><p>${t('ai.widget.generating')}</p></div>`;
    }
    const report = await this.generate(true);
    this.renderWidget(containerId, report);
  }
};

/* ============================================================
   HELPER UTILITIES
   ============================================================ */

function _escHtml(str) {
  return String(str || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

/* ============================================================
   OVERRIDE EXISTING PAGE RENDERERS
   ============================================================ */

// Wait for DOM + existing renderers, then override
window.addEventListener('load', function () {
  // Override page renderers with enhanced versions
  if (typeof renderAISettingsPage !== 'undefined') {
    window.renderAISettingsPage = renderAISettingsPageEnhanced;
  }
  if (typeof renderAIAnalyticsPage !== 'undefined') {
    window.renderAIAnalyticsPage = renderAIAnalyticsPageEnhanced;
  }
  if (typeof renderAIAutomationPage !== 'undefined') {
    window.renderAIAutomationPage = renderAIAutomationPageEnhanced;
  }
  if (typeof renderAIPersonalityPage !== 'undefined') {
    window.renderAIPersonalityPage = renderAIPersonalityPageEnhanced;
  }

  // Expose widget globally
  window.AIDashboardWidget = AIDashboardWidget;

  // Initialize AI daily report widget on dashboard if container exists
  setTimeout(() => {
    const widgetContainer = document.getElementById('aiDashboardWidget');
    if (widgetContainer) {
      const storedReport = AIDashboardWidget.getStored();
      AIDashboardWidget.renderWidget('aiDashboardWidget', storedReport);
    }
  }, 1000);

  // Expose enhanced functions globally
  window.switchSettingsTab = switchSettingsTab;
  window.testProviderConnection = testProviderConnection;
  window.openAddAutomationModal = openAddAutomationModal;
  window.closeAutomationModal = closeAutomationModal;
  window.saveNewAutomation = saveNewAutomation;
  window.toggleAutomation = toggleAutomation;
  window.applyAutomationTemplate = applyAutomationTemplate;
  window.selectProfile = selectProfile;
  window.saveActiveProfile = saveActiveProfile;
  window.addBehaviourRule = addBehaviourRule;
  window.removeBehaviourRule = removeBehaviourRule;
  window.openAddProfileModal = openAddProfileModal;
  window.closeProfileModal = closeProfileModal;
  window.createNewProfile = createNewProfile;
  window.deleteProfile = deleteProfile;
  window.showAddMemoryDialog = showAddMemoryDialog;
  window.deleteMemoryItem = deleteMemoryItem;
});
