/* ============================================================
   MURAD LEARNING PLANNER - Dynamic Floating Dock System v2.0
   Replaces: #guideBtn + #floatingAI
   Features: AI Assistant, User Guide, Notifications, Quick Actions
   Auto-positioning, collision detection, responsive
   ============================================================ */

(function () {
  'use strict';

  // ── Dock State ───────────────────────────────────────────────
  const DockState = {
    open: false,
    activePanel: null,   // 'ai' | 'guide' | 'notif' | 'quick'
    notifications: [],
    unreadCount: 0,
    panels: {},
    position: { side: 'right', bottom: 24 }
  };

  // ── Notification Manager ─────────────────────────────────────
  const DockNotifications = {
    add(msg, type = 'info', source = '') {
      const notif = {
        id: 'n_' + Date.now() + '_' + Math.random().toString(36).slice(2, 7),
        message: msg,
        type,        // 'info' | 'success' | 'warning' | 'error' | 'ai'
        source,
        time: new Date(),
        read: false
      };
      DockState.notifications.unshift(notif);
      // Keep max 50
      if (DockState.notifications.length > 50) DockState.notifications.pop();
      DockState.unreadCount++;
      _savePersistentNotifications();
      _updateBadge();
      _renderNotifPanel();
      return notif.id;
    },

    markAllRead() {
      DockState.notifications.forEach(n => n.read = true);
      DockState.unreadCount = 0;
      _savePersistentNotifications();
      _updateBadge();
      _renderNotifPanel();
    },

    clearAll() {
      DockState.notifications = [];
      DockState.unreadCount = 0;
      _savePersistentNotifications();
      _updateBadge();
      _renderNotifPanel();
    },

    getAll() { return DockState.notifications; }
  };

  function _savePersistentNotifications() {
    try {
      // Keep last 20 in storage
      const toSave = DockState.notifications.slice(0, 20);
      localStorage.setItem('murad_dock_notifications', JSON.stringify(toSave));
    } catch (e) { /* quota or parse error */ }
  }

  function _loadPersistedNotifications() {
    try {
      const raw = localStorage.getItem('murad_dock_notifications');
      if (raw) {
        const data = JSON.parse(raw);
        DockState.notifications = data.map(n => ({ ...n, time: new Date(n.time) }));
        DockState.unreadCount = DockState.notifications.filter(n => !n.read).length;
      }
    } catch (e) { /* ignore */ }
  }

  // ── Badge update ─────────────────────────────────────────────
  function _updateBadge() {
    const badge = document.getElementById('dockNotifBadge');
    if (!badge) return;
    if (DockState.unreadCount > 0) {
      badge.textContent = DockState.unreadCount > 99 ? '99+' : DockState.unreadCount;
      badge.style.display = 'flex';
    } else {
      badge.style.display = 'none';
    }
  }

  // ── Build Dock HTML ──────────────────────────────────────────
  function _buildDock() {
    // Remove old conflicting elements
    ['guideBtn', 'floatingAI'].forEach(id => {
      const old = document.getElementById(id);
      if (old && old.parentNode) old.parentNode.removeChild(old);
    });

    const dock = document.createElement('div');
    dock.id = 'floatingDock';
    dock.className = 'floating-dock';
    dock.setAttribute('role', 'complementary');
    dock.setAttribute('aria-label', 'Floating Dock');

    dock.innerHTML = `
      <!-- Main Toggle Button -->
      <button class="dock-main-btn" id="dockMainBtn" onclick="DockSystem.toggle()" 
              title="${window.t ? t('dock.quickActions') : 'Quick Actions'}" 
              aria-expanded="false" aria-controls="dockMenu">
        <i class="fas fa-robot dock-icon-ai" aria-hidden="true"></i>
        <i class="fas fa-times dock-icon-close" aria-hidden="true" style="display:none"></i>
        <span class="dock-pulse"></span>
      </button>

      <!-- Dock Menu Items -->
      <div class="dock-menu" id="dockMenu" role="menu" aria-hidden="true">
        
        <!-- AI Assistant -->
        <div class="dock-item" id="dockItemAI" role="menuitem">
          <button class="dock-item-btn" onclick="DockSystem.openPanel('ai')" 
                  title="${window.t ? t('dock.aiAssistant') : 'AI Assistant'}">
            <i class="fas fa-comments"></i>
            <span class="dock-badge ai-badge" id="dockAIBadge" style="display:none">!</span>
          </button>
          <span class="dock-tooltip">${window.t ? t('dock.aiAssistant') : 'AI Assistant'}</span>
        </div>

        <!-- User Guide -->
        <div class="dock-item" id="dockItemGuide" role="menuitem">
          <button class="dock-item-btn" onclick="DockSystem.openPanel('guide')" 
                  title="${window.t ? t('dock.userGuide') : 'User Guide'}">
            <i class="fas fa-book-open"></i>
          </button>
          <span class="dock-tooltip">${window.t ? t('dock.userGuide') : 'User Guide'}</span>
        </div>

        <!-- Notifications -->
        <div class="dock-item" id="dockItemNotif" role="menuitem">
          <button class="dock-item-btn" onclick="DockSystem.openPanel('notif')" 
                  title="${window.t ? t('dock.notifications') : 'Notifications'}">
            <i class="fas fa-bell"></i>
            <span class="dock-badge" id="dockNotifBadge" style="display:none">0</span>
          </button>
          <span class="dock-tooltip">${window.t ? t('dock.notifications') : 'Notifications'}</span>
        </div>

        <!-- Quick Actions -->
        <div class="dock-item" id="dockItemQuick" role="menuitem">
          <button class="dock-item-btn" onclick="DockSystem.openPanel('quick')" 
                  title="${window.t ? t('dock.quickActions') : 'Quick Actions'}">
            <i class="fas fa-bolt"></i>
          </button>
          <span class="dock-tooltip">${window.t ? t('dock.quickActions') : 'Quick Actions'}</span>
        </div>

      </div>

      <!-- ── PANELS ─────────────────────────────────────── -->

      <!-- AI Panel (mini chat) -->
      <div class="dock-panel" id="dockPanelAI" style="display:none" role="dialog" aria-label="AI Assistant">
        <div class="dock-panel-header">
          <div class="dock-panel-title">
            <i class="fas fa-robot"></i>
            <span id="dockAITitle">${window.t ? t('dock.aiAssistant') : 'AI Assistant'}</span>
          </div>
          <div class="dock-panel-actions">
            <button onclick="DockSystem.openFull('ai')" title="${window.t ? t('dock.openFull') : 'Open Full'}" class="dock-expand-btn">
              <i class="fas fa-expand-alt"></i>
            </button>
            <button onclick="DockSystem.closePanel()" class="dock-close-btn" title="${window.t ? t('dock.close') : 'Close'}">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>
        <div class="dock-panel-context" id="dockAIContext"></div>
        <div class="dock-panel-messages" id="dockAIMessages">
          <div class="dock-welcome">
            <i class="fas fa-robot"></i>
            <p>${window.t ? t('ai.workspace.welcome') : 'How can I help you?'}</p>
          </div>
        </div>
        <div class="dock-quick-prompts" id="dockQuickPrompts">
          <button onclick="DockSystem.sendQuick('${window.t ? t('ai.workspace.sugg1') : 'Analyze my progress'}')">${window.t ? t('ai.workspace.sugg1') : 'Analyze my progress'}</button>
          <button onclick="DockSystem.sendQuick('${window.t ? t('ai.workspace.sugg2') : 'Suggest study plan'}')">${window.t ? t('ai.workspace.sugg2') : 'Suggest study plan'}</button>
        </div>
        <div class="dock-panel-input">
          <textarea id="dockAIInput" class="dock-input" rows="1"
            placeholder="${window.t ? t('ai.workspace.inputPlaceholder') : 'Type a message...'}"
            onkeydown="DockSystem.handleKey(event)"
            oninput="DockSystem.autoResize(this)"></textarea>
          <div class="dock-input-actions">
            <button class="dock-voice-btn" id="dockVoiceBtn" onclick="DockSystem.toggleVoice()" title="Voice">
              <i class="fas fa-microphone"></i>
            </button>
            <button class="dock-send-btn" onclick="DockSystem.send()" title="${window.t ? t('ai.workspace.send') : 'Send'}">
              <i class="fas fa-paper-plane"></i>
            </button>
          </div>
        </div>
        <div class="dock-typing" id="dockTyping" style="display:none">
          <span></span><span></span><span></span>
        </div>
      </div>

      <!-- Guide Panel -->
      <div class="dock-panel" id="dockPanelGuide" style="display:none" role="dialog" aria-label="User Guide">
        <div class="dock-panel-header">
          <div class="dock-panel-title">
            <i class="fas fa-book-open"></i>
            <span>${window.t ? t('dock.userGuide') : 'User Guide'}</span>
          </div>
          <button onclick="DockSystem.closePanel()" class="dock-close-btn" title="${window.t ? t('dock.close') : 'Close'}">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="dock-panel-content guide-content-dock" id="dockGuideContent">
          ${_buildGuideContent()}
        </div>
      </div>

      <!-- Notifications Panel -->
      <div class="dock-panel" id="dockPanelNotif" style="display:none" role="dialog" aria-label="Notifications">
        <div class="dock-panel-header">
          <div class="dock-panel-title">
            <i class="fas fa-bell"></i>
            <span>${window.t ? t('notif.title') : 'Notifications'}</span>
          </div>
          <div class="dock-panel-actions">
            <button onclick="DockSystem.markAllRead()" title="${window.t ? t('notif.markRead') : 'Mark all read'}" class="dock-text-btn">
              <i class="fas fa-check-double"></i>
            </button>
            <button onclick="DockSystem.clearNotifications()" title="${window.t ? t('notif.clearAll') : 'Clear All'}" class="dock-text-btn">
              <i class="fas fa-trash"></i>
            </button>
            <button onclick="DockSystem.closePanel()" class="dock-close-btn">
              <i class="fas fa-times"></i>
            </button>
          </div>
        </div>
        <div class="dock-panel-content" id="dockNotifList">
          <div class="dock-empty">
            <i class="fas fa-bell-slash"></i>
            <p>${window.t ? t('notif.noNotifications') : 'No notifications'}</p>
          </div>
        </div>
      </div>

      <!-- Quick Actions Panel -->
      <div class="dock-panel" id="dockPanelQuick" style="display:none" role="dialog" aria-label="Quick Actions">
        <div class="dock-panel-header">
          <div class="dock-panel-title">
            <i class="fas fa-bolt"></i>
            <span>${window.t ? t('quick.title') : 'Quick Actions'}</span>
          </div>
          <button onclick="DockSystem.closePanel()" class="dock-close-btn">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="dock-panel-content">
          <div class="quick-actions-grid">
            <button class="quick-action-btn" onclick="DockSystem.quickAction('session')">
              <i class="fas fa-play-circle"></i>
              <span>${window.t ? t('quick.newSession') : 'New Session'}</span>
            </button>
            <button class="quick-action-btn" onclick="DockSystem.quickAction('ai')">
              <i class="fas fa-robot"></i>
              <span>${window.t ? t('quick.askAI') : 'Ask AI'}</span>
            </button>
            <button class="quick-action-btn" onclick="DockSystem.quickAction('schedule')">
              <i class="fas fa-calendar-week"></i>
              <span>${window.t ? t('quick.viewSchedule') : 'View Schedule'}</span>
            </button>
            <button class="quick-action-btn" onclick="DockSystem.quickAction('goal')">
              <i class="fas fa-bullseye"></i>
              <span>${window.t ? t('quick.addGoal') : 'Add Goal'}</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Backdrop -->
      <div class="dock-backdrop" id="dockBackdrop" onclick="DockSystem.close()" style="display:none"></div>
    `;

    document.body.appendChild(dock);
    _loadPersistedNotifications();
    _updateBadge();
    _applyPositioning();
  }

  // ── Guide content ────────────────────────────────────────────
  function _buildGuideContent() {
    return `
      <div class="guide-dock-tabs">
        <button class="guide-dock-tab active" onclick="DockSystem.switchGuideTab(event,'overview')">📋</button>
        <button class="guide-dock-tab" onclick="DockSystem.switchGuideTab(event,'patterns')">🔄</button>
        <button class="guide-dock-tab" onclick="DockSystem.switchGuideTab(event,'timer')">⏱️</button>
        <button class="guide-dock-tab" onclick="DockSystem.switchGuideTab(event,'ai')">🤖</button>
      </div>
      <div class="guide-dock-section active" id="guideTab_overview">
        <h4>📋 ${window.t ? t('nav.dashboard') : 'Dashboard'}</h4>
        <p>${window.t ? t('dashboard.subtitle') : 'Advanced Daily Learning System'}</p>
        <ul>
          <li>📊 Track daily and weekly progress</li>
          <li>🎯 Set and manage study goals</li>
          <li>⏱️ Use the built-in timer for focus blocks</li>
          <li>🤖 Get AI-powered recommendations</li>
        </ul>
      </div>
      <div class="guide-dock-section" id="guideTab_patterns">
        <h4>🔄 Learning Patterns</h4>
        <p><strong>Pattern A:</strong> New concepts & exploration</p>
        <p><strong>Pattern B:</strong> Reinforcement & practice</p>
        <p><strong>Pattern C:</strong> Integration & connecting ideas</p>
        <p><strong>Pattern D:</strong> Testing & weekly closure</p>
      </div>
      <div class="guide-dock-section" id="guideTab_timer">
        <h4>⏱️ Timer Guide</h4>
        <p>Use the study timer to:</p>
        <ul>
          <li>Track block duration</li>
          <li>Get notifications on completion</li>
          <li>Skip or reset as needed</li>
        </ul>
      </div>
      <div class="guide-dock-section" id="guideTab_ai">
        <h4>🤖 AI Assistant</h4>
        <p>Your AI can:</p>
        <ul>
          <li>💬 Answer study questions</li>
          <li>📋 Create and modify schedules</li>
          <li>📊 Analyze your performance</li>
          <li>🎯 Set goals for you</li>
          <li>📝 Take notes automatically</li>
        </ul>
        <p>Try: "Create today's study plan" or "Analyze my week"</p>
      </div>
    `;
  }

  // ── Positioning Logic ─────────────────────────────────────────
  function _applyPositioning() {
    const dock = document.getElementById('floatingDock');
    if (!dock) return;

    const isRTL = document.documentElement.getAttribute('dir') === 'rtl';
    const isMobile = window.innerWidth < 768;

    dock.style.bottom = DockState.position.bottom + 'px';
    dock.style.right = isRTL ? 'auto' : '24px';
    dock.style.left = isRTL ? '24px' : 'auto';

    // Panel positioning
    ['AI', 'Guide', 'Notif', 'Quick'].forEach(name => {
      const panel = document.getElementById('dockPanel' + name);
      if (panel) {
        if (isMobile) {
          panel.style.bottom = '80px';
          panel.style.left = '8px';
          panel.style.right = '8px';
          panel.style.width = 'auto';
          panel.style.maxHeight = 'calc(100vh - 120px)';
        } else {
          panel.style.bottom = '80px';
          if (isRTL) {
            panel.style.left = '0';
            panel.style.right = 'auto';
          } else {
            panel.style.right = '0';
            panel.style.left = 'auto';
          }
          panel.style.width = '380px';
          panel.style.maxHeight = 'calc(100vh - 140px)';
        }
      }
    });
  }

  // ── Dock Toggle ──────────────────────────────────────────────
  function toggle() {
    if (DockState.open) {
      close();
    } else {
      open();
    }
  }

  function open() {
    DockState.open = true;
    const menu = document.getElementById('dockMenu');
    const btn = document.getElementById('dockMainBtn');
    const backdrop = document.getElementById('dockBackdrop');
    if (menu) { menu.classList.add('open'); menu.setAttribute('aria-hidden', 'false'); }
    if (btn) {
      btn.setAttribute('aria-expanded', 'true');
      btn.querySelector('.dock-icon-ai').style.display = 'none';
      btn.querySelector('.dock-icon-close').style.display = '';
    }
    if (backdrop) backdrop.style.display = 'block';
  }

  function close() {
    DockState.open = false;
    DockState.activePanel = null;
    const menu = document.getElementById('dockMenu');
    const btn = document.getElementById('dockMainBtn');
    const backdrop = document.getElementById('dockBackdrop');
    if (menu) { menu.classList.remove('open'); menu.setAttribute('aria-hidden', 'true'); }
    if (btn) {
      btn.setAttribute('aria-expanded', 'false');
      btn.querySelector('.dock-icon-ai').style.display = '';
      btn.querySelector('.dock-icon-close').style.display = 'none';
    }
    if (backdrop) backdrop.style.display = 'none';
    _hideAllPanels();
  }

  function _hideAllPanels() {
    ['AI', 'Guide', 'Notif', 'Quick'].forEach(name => {
      const p = document.getElementById('dockPanel' + name);
      if (p) p.style.display = 'none';
    });
    // Remove active class from items
    document.querySelectorAll('.dock-item-btn').forEach(b => b.classList.remove('active'));
  }

  // ── Panel Management ─────────────────────────────────────────
  function openPanel(panelName) {
    if (!DockState.open) open();

    const panelMap = { ai: 'AI', guide: 'Guide', notif: 'Notif', quick: 'Quick' };
    const panelId = panelMap[panelName];
    if (!panelId) return;

    // Toggle: if already open, close
    if (DockState.activePanel === panelName) {
      closePanel();
      return;
    }

    _hideAllPanels();
    DockState.activePanel = panelName;

    const panel = document.getElementById('dockPanel' + panelId);
    if (panel) {
      panel.style.display = 'flex';
      panel.setAttribute('aria-hidden', 'false');
    }

    // Mark item as active
    const itemId = { ai: 'dockItemAI', guide: 'dockItemGuide', notif: 'dockItemNotif', quick: 'dockItemQuick' };
    document.querySelectorAll('.dock-item-btn').forEach(b => b.classList.remove('active'));
    const itemBtn = document.querySelector(`#${itemId[panelName]} .dock-item-btn`);
    if (itemBtn) itemBtn.classList.add('active');

    // Panel-specific init
    if (panelName === 'notif') {
      DockNotifications.markAllRead();
      _renderNotifPanel();
    }
    if (panelName === 'ai') {
      updateDockContext();
      setTimeout(() => document.getElementById('dockAIInput')?.focus(), 100);
    }
    if (panelName === 'guide') {
      // Switch to first tab
      const firstTab = document.querySelector('.guide-dock-tab.active');
      if (!firstTab) {
        const tabs = document.querySelectorAll('.guide-dock-tab');
        if (tabs[0]) tabs[0].click();
      }
    }
  }

  function closePanel() {
    _hideAllPanels();
    DockState.activePanel = null;
  }

  function openFull(section) {
    close();
    if (section === 'ai') {
      if (window.showAIPage) showAIPage('ai-workspace');
      else if (window.showPage) showPage('ai-workspace');
    }
  }

  // ── Guide tabs ───────────────────────────────────────────────
  function switchGuideTab(event, tabName) {
    event.stopPropagation();
    document.querySelectorAll('.guide-dock-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.guide-dock-section').forEach(s => s.classList.remove('active'));
    event.currentTarget.classList.add('active');
    const section = document.getElementById('guideTab_' + tabName);
    if (section) section.classList.add('active');
  }

  // ── Notification rendering ────────────────────────────────────
  function _renderNotifPanel() {
    const list = document.getElementById('dockNotifList');
    if (!list) return;

    const notifs = DockState.notifications;
    if (!notifs.length) {
      list.innerHTML = `<div class="dock-empty"><i class="fas fa-bell-slash"></i><p>${window.t ? t('notif.noNotifications') : 'No notifications'}</p></div>`;
      return;
    }

    list.innerHTML = notifs.map(n => {
      const iconMap = { info: 'fa-info-circle', success: 'fa-check-circle', warning: 'fa-exclamation-triangle', error: 'fa-times-circle', ai: 'fa-robot' };
      const icon = iconMap[n.type] || 'fa-info-circle';
      const timeStr = _relativeTime(n.time);
      return `
        <div class="dock-notif-item ${n.read ? 'read' : 'unread'} type-${n.type}">
          <i class="fas ${icon} notif-icon"></i>
          <div class="notif-body">
            <p>${_escapeHtml(n.message)}</p>
            ${n.source ? `<span class="notif-source">${_escapeHtml(n.source)}</span>` : ''}
          </div>
          <span class="notif-time">${timeStr}</span>
        </div>
      `;
    }).join('');
  }

  function _relativeTime(date) {
    const now = new Date();
    const diff = Math.floor((now - date) / 1000);
    if (diff < 60) return window.t ? t('notif.just') : 'just now';
    if (diff < 3600) return `${Math.floor(diff / 60)} ${window.t ? t('notif.min') : 'min'} ${window.t ? t('notif.ago') : 'ago'}`;
    if (diff < 86400) return `${Math.floor(diff / 3600)} ${window.t ? t('notif.hour') : 'hour'} ${window.t ? t('notif.ago') : 'ago'}`;
    return `${Math.floor(diff / 86400)} ${window.t ? t('notif.day') : 'day'} ${window.t ? t('notif.ago') : 'ago'}`;
  }

  function markAllRead() {
    DockNotifications.markAllRead();
  }

  function clearNotifications() {
    DockNotifications.clearAll();
  }

  // ── AI Chat ──────────────────────────────────────────────────
  function updateDockContext() {
    const ctxEl = document.getElementById('dockAIContext');
    if (!ctxEl) return;
    try {
      const ctx = window.AIAgent ? AIAgent.getAppContext() : null;
      if (ctx) {
        const page = ctx.currentState?.page || '';
        const day = ctx.currentState?.day || '';
        ctxEl.textContent = [page, day].filter(Boolean).join(' · ');
      } else {
        ctxEl.textContent = '';
      }
    } catch (e) {
      ctxEl.textContent = '';
    }
  }

  function send() {
    const input = document.getElementById('dockAIInput');
    const msg = input ? input.value.trim() : '';
    if (!msg) return;
    _addDockMessage('user', msg);
    if (input) { input.value = ''; input.style.height = 'auto'; }
    _hideDockQuickPrompts();
    _showTyping(true);
    _sendToAI(msg);
  }

  function sendQuick(msg) {
    if (!msg) return;
    _addDockMessage('user', msg);
    _hideDockQuickPrompts();
    _showTyping(true);
    _sendToAI(msg);
  }

  function handleKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      send();
    }
  }

  function autoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }

  function _hideDockQuickPrompts() {
    const qp = document.getElementById('dockQuickPrompts');
    if (qp) qp.style.display = 'none';
  }

  function _showTyping(show) {
    const typing = document.getElementById('dockTyping');
    if (typing) typing.style.display = show ? 'flex' : 'none';
  }

  function _addDockMessage(role, text) {
    const msgs = document.getElementById('dockAIMessages');
    if (!msgs) return;
    // Remove welcome if present
    const welcome = msgs.querySelector('.dock-welcome');
    if (welcome) welcome.remove();

    const div = document.createElement('div');
    div.className = `dock-msg dock-msg-${role}`;
    div.innerHTML = `<div class="dock-msg-bubble">${role === 'ai' ? (window.renderMarkdown ? renderMarkdown(text) : _escapeHtml(text)) : _escapeHtml(text)}</div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function _sendToAI(text) {
    // Check provider
    const provider = window.AIProviders ? AIProviders.getActiveProvider() : null;
    if (!provider || !provider.apiKey) {
      _showTyping(false);
      _addDockMessage('ai', window.t ? t('ai.workspace.noProvider') : 'No AI provider configured. Please set up a provider in AI Settings.');
      return;
    }

    try {
      const systemPrompt = window.AIAgent ? AIAgent.buildSystemPrompt() : 'You are a helpful AI learning assistant.';
      const messages = [{ role: 'user', content: text }];

      window.AIChat.sendMessageStream(systemPrompt, messages, (chunk) => {
        // Accumulate in state
        if (!_sendToAI._buffer) _sendToAI._buffer = '';
        _sendToAI._buffer += chunk;
      }, () => {
        // Done
        _showTyping(false);
        const resp = _sendToAI._buffer || '';
        _sendToAI._buffer = '';
        _addDockMessage('ai', resp);
        // Parse tools
        if (window.AIAgent) AIAgent.parseAndExecuteTools(resp);
        // Add to notification
        DockNotifications.add('AI responded', 'ai', 'AI Assistant');
      }, (err) => {
        _showTyping(false);
        _sendToAI._buffer = '';
        _addDockMessage('ai', '⚠️ ' + (err?.message || 'An error occurred'));
      });
    } catch (err) {
      _showTyping(false);
      _addDockMessage('ai', '⚠️ ' + err.message);
    }
  }

  // ── Voice Input ───────────────────────────────────────────────
  let _recognition = null;
  let _voiceActive = false;

  function toggleVoice() {
    if (_voiceActive) {
      _stopVoice();
    } else {
      _startVoice();
    }
  }

  function _startVoice() {
    const SRClass = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SRClass) {
      if (typeof showToast === 'function') showToast('Speech recognition not supported', 'error');
      return;
    }
    _recognition = new SRClass();
    _recognition.continuous = false;
    _recognition.interimResults = false;
    _recognition.lang = window.getCurrentLang ? (getCurrentLang() === 'ar' ? 'ar-SA' : getCurrentLang() === 'id' ? 'id-ID' : 'en-US') : 'en-US';

    _recognition.onresult = (e) => {
      const transcript = e.results[0][0].transcript;
      const input = document.getElementById('dockAIInput');
      if (input) { input.value = transcript; autoResize(input); }
    };
    _recognition.onend = () => { _voiceActive = false; _updateVoiceBtn(false); };
    _recognition.onerror = () => { _voiceActive = false; _updateVoiceBtn(false); };

    _recognition.start();
    _voiceActive = true;
    _updateVoiceBtn(true);
  }

  function _stopVoice() {
    if (_recognition) { try { _recognition.stop(); } catch (e) { /* ignore */ } }
    _voiceActive = false;
    _updateVoiceBtn(false);
  }

  function _updateVoiceBtn(active) {
    const btn = document.getElementById('dockVoiceBtn');
    if (btn) btn.classList.toggle('active', active);
  }

  // ── Quick Actions ─────────────────────────────────────────────
  function quickAction(type) {
    close();
    switch (type) {
      case 'session':
        if (window.showPage) showPage('dashboard');
        break;
      case 'ai':
        if (window.showAIPage) showAIPage('ai-workspace');
        break;
      case 'schedule':
        if (window.showPage) showPage('weekly');
        break;
      case 'goal':
        openPanel('ai');
        setTimeout(() => {
          const input = document.getElementById('dockAIInput');
          if (input) input.value = window.t ? t('quick.addGoal') + ': ' : 'Add goal: ';
        }, 200);
        break;
    }
  }

  // ── Responsive resize ─────────────────────────────────────────
  function _handleResize() {
    _applyPositioning();
    if (DockState.activePanel) {
      // Re-position open panel
      _applyPositioning();
    }
  }

  // ── Accessibility ─────────────────────────────────────────────
  function _handleEsc(e) {
    if (e.key === 'Escape' && DockState.open) close();
  }

  // ── Utilities ─────────────────────────────────────────────────
  function _escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── Language change observer ─────────────────────────────────
  function _onLangChange() {
    const dock = document.getElementById('floatingDock');
    if (dock) {
      dock.remove();
      _buildDock();
      _renderNotifPanel();
    }
    _applyPositioning();
  }

  // ── Public API ───────────────────────────────────────────────
  const DockSystem = {
    toggle,
    open,
    close,
    openPanel,
    closePanel,
    openFull,
    send,
    sendQuick,
    handleKey,
    autoResize,
    switchGuideTab,
    toggleVoice,
    quickAction,
    markAllRead,
    clearNotifications,
    notify: (msg, type, source) => DockNotifications.add(msg, type, source),
    updateContext: updateDockContext,
    notifications: DockNotifications,
    getState: () => ({ ...DockState })
  };

  // ── Initialize ───────────────────────────────────────────────
  function init() {
    _buildDock();
    window.addEventListener('resize', _handleResize);
    document.addEventListener('keydown', _handleEsc);

    // Update lang observer
    if (window.onLanguageChange) {
      onLanguageChange(_onLangChange);
    }

    // Expose globally
    window.DockSystem = DockSystem;
    window.DockNotifications = DockNotifications;

    // Also expose legacy toggleUserGuide for old code that calls it
    window.toggleUserGuide = () => DockSystem.openPanel('guide');
    window.closeUserGuide = () => DockSystem.closePanel();
    window.updateDockContext = updateDockContext;
    window.updateFloatingAIContext = updateDockContext; // legacy compat

    // Add initial welcome notification
    setTimeout(() => {
      DockNotifications.add(
        window.t ? t('dashboard.subtitle') : 'Welcome to Murad Learning Planner',
        'info',
        'System'
      );
    }, 2000);
  }

  // Wait for DOM
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
